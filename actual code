    } else {
        if (momCheck == 1 && dadCheck == 2) {
            cout << "\nColorblind Male - 50%\n";
            cout << "Carrier Female - 50%";
        } else {
            if (momCheck == 2 && dadCheck == 1) {
                cout << "\nNon-Colorblind Male - 50%\n";
